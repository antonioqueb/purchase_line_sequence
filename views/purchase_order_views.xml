<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_order_form_inherit_line_sequence" model="ir.ui.view">
        <field name="name">purchase.order.form.line.sequence</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//list//field[@name='product_id']" position="before">
                <field name="x_line_number" string="#" width="40px" readonly="1"
                       column_invisible="parent.state == 'cancel'"
                       decoration-bf="1"/>
            </xpath>
        </field>
    </record>
</odoo>
